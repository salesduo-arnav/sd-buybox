# ============================================================
# Buybox — environment template
# ------------------------------------------------------------
# Copy this file to `.env` and fill in the secrets. The file is
# structured to support two dev flows; comments mark which block
# applies to which.
#
#   Flow A — docker (canonical full stack)
#     Everything runs in docker. Browser talks to buybox.lvh.me
#     via sd-core-platform's gateway. Cookie is shared through
#     COOKIE_DOMAIN=.lvh.me on the core-platform side.
#     Run core-platform first (`make dev`) so the shared
#     `salesduo-net` docker network exists.
#
#   Flow B — non-docker (raw `npm run dev`)
#     Both stacks run on localhost with different ports. Cookie
#     is host-only on localhost (core-platform .env must leave
#     COOKIE_DOMAIN unset) and is shared across ports because
#     cookies key on host, not port.
#
# docker-compose.yml overrides PGHOST, PGPORT, CORE_PLATFORM_URL,
# CORE_PLATFORM_INTERNAL_URL, and CORS_ORIGINS for container runtime,
# so this file is primarily for Flow B (non-docker).
# ============================================================

# --- Database (Flow B defaults; Flow A uses docker service names) ---
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=buybox_dev
PGHOST=localhost
PGPORT=5434

# --- Server ---
PORT=5003
NODE_ENV=development

# --- Core Platform (shared cookie auth) ---
# Browser-facing URL of the core-platform frontend — used for login redirects.
#   Flow A: http://app.lvh.me
#   Flow B: http://localhost:5173
CORE_PLATFORM_URL=http://localhost:5173

# Service-to-service URL (buybox backend -> core-platform backend).
#   Flow A (set by docker-compose): http://core-backend:3000
#   Flow B:                         http://localhost:3000
CORE_PLATFORM_INTERNAL_URL=http://localhost:3000

# Optional tunables for the core-platform client / session cache.
# CORE_PLATFORM_TIMEOUT_MS=15000        # default timeout for /internal/* calls
# CORE_PLATFORM_AUTH_TIMEOUT_MS=5000    # /auth/me + /auth/logout (kept short — on the request hot path)
# CORE_PLATFORM_AUDIT_TIMEOUT_MS=10000  # /internal/audit-logs (best-effort, fire-and-forget)
# SESSION_CACHE_TTL_MS=60000
# SESSION_COOKIE_NAME=session_id

# --- Internal service auth (MUST match core-platform's INTERNAL_API_KEY) ---
INTERNAL_API_KEY=your-internal-api-key-here
INTERNAL_SERVICE_NAME=buybox

# --- Frontend build args (Vite inlines these at build time) ---
#   Flow A: http://buybox.lvh.me / http://app.lvh.me
#   Flow B: http://localhost:5003 / http://localhost:5173
VITE_API_BASE_URL=http://localhost:5003
VITE_CORE_PLATFORM_URL=http://localhost:5173

# --- Amazon SP-API ---
SP_API_CLIENT_ID=
SP_API_CLIENT_SECRET=
SP_API_ENDPOINT=https://sellingpartnerapi-na.amazon.com

# --- Logging ---
LOG_LEVEL=debug

# --- CORS (browser-facing origins allowed to call this backend) ---
#   Flow A: http://buybox.lvh.me
#   Flow B: http://localhost:5004
CORS_ORIGINS=http://localhost:5004
