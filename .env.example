# Database
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=buybox_dev
PGHOST=postgres
PGPORT=5434

# Server
PORT=5003
NODE_ENV=development

# Gateway
GATEWAY_PORT=5175

# Core Platform (shared cookie auth)
CORE_PLATFORM_URL=http://localhost:4001
CORE_PLATFORM_INTERNAL_URL=http://core-backend:4001

# Internal Service Key (for service-to-service calls to core-platform)
INTERNAL_API_KEY=your-internal-api-key-here
INTERNAL_SERVICE_NAME=buybox

# Frontend
VITE_API_BASE_URL=/api
VITE_CORE_PLATFORM_URL=http://localhost:5173

# SP-API (Amazon Selling Partner API)
SP_API_CLIENT_ID=
SP_API_CLIENT_SECRET=
SP_API_ENDPOINT=https://sellingpartnerapi-na.amazon.com

# Logging
LOG_LEVEL=debug


# CORS
CORS_ORIGINS=http://localhost:5175,http://localhost:5004
